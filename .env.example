# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# LOCATION & WEATHER (§689): the app NO LONGER holds any Ola Maps key.
# All location (Places autocomplete, geocode, reverse, directions) AND weather
# (current / forecast / air-quality) traffic is proxied through the OdioBook GEO
# gateway at {server}/api/geo/*, which injects the admin-managed Ola REST key
# server-side. The only thing configurable in the app is the OdioBook SERVER URL
# (Settings → Advanced → "OdioBook Server URL"), default https://odiobook.com.
# Which map/weather features are on, and the restricted map-tile key used to draw
# tiles on-device, are fetched at runtime from {server}/api/geo/app-config?app=solaris
# and managed entirely from the OdioBook admin "Location & Maps" tab.
