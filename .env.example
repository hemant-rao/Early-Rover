# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# OLA_MAPS_API_KEY: Used by the Travel map (MapLibre + Ola tiles), Places autocomplete,
# geocoding and directions. NOTE: the app reads this key at runtime from the in-app
# admin config (Settings > Advanced > Ola Maps API Key), NOT from this file. This entry
# is documentation only. Get a key from https://maps.olakrutrim.com/pricing
OLA_MAPS_API_KEY=MY_OLA_MAPS_API_KEY
